FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      optProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

raa0                1e-5;
voluse              0.4;
mma_init            0.2;
mma_dec             0.6;
mma_inc             1.1;
movlim              0.2;
filterR             5;
PowerDiss0          1.2e-3;
PowerDissMax        4;
PowerDissRelax      5;
GeoDim              2;
fluid_area          yes;
solid_area          no;
test_area           no;
Pnorm               300;
objFunction         1;

