FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    // Keep only unresolved-issue controls for the next run.

    // Smooth projection (tanh) + sharper continuation to reduce gray stagnation.
    optProjectionBetaScaleStart 0.4;
    optProjectionBetaScaleEnd   2.8;
    optProjectionBetaRampStartIteration 20;
    optProjectionBetaRampEndIteration   120;
    optProjectionDelStepStart 0.22;
    optProjectionDelStepEnd   0.50;
    optProjectionDelStepRampStartIteration 25;
    optProjectionDelStepRampEndIteration   120;

    // Trust-definition collapse fix.
    optStabilityContinuationGovernorTrustUndefinedBlocks false;
    optTrustPredReductionAbsFloor 1e-16;
    optTrustPredReductionRelFloor 1e-12;

    // Late-stage filter/projection/binarization continuation.
    optFilterStrengthRampStartIteration 60;
    optFilterStrengthRampEndIteration   150;
    optFilterRadiusScaleMin 0.45; // shrink late filter radius more aggressively.

    optMaterialInterpolationExponentEnd   3.5;
    optMaterialInterpolationExponentRampStartIteration 20;
    optMaterialInterpolationExponentRampEndIteration   130;

    // Grayness penalty: integral(xh*(1-xh)) to drive 0/1 design.
    optGrayPenaltyWeightStart 0.02;
    optGrayPenaltyWeightEnd   0.70;
    optGrayPenaltyRampStartIteration 20;
    optGrayPenaltyRampEndIteration   140;

    // MMA stagnation recovery for tiny x-step windows.
    optMMAStagnationStepThreshold 2e-5;
    optMMAStagnationWindow 6;
    optMMAStagnationMoveLimitBoost 2.0;
    optMMAStagnationMoveLimitCap   0.30;

    // Keep Aitken acceleration for adjoint no-improve behavior.
    optAdjointAitkenOmegaMin 0.20;
    optAdjointAitkenOmegaMax 0.95;

    // Wall-function diagnostics disabled for low-Re wall-treatment run.
    optWallFunctionYPlusDiagnosticsEnable false;

    // Prevent trust-undefined latch in converged gray-trust gate.
    optConvergedGrayTrustGateUndefinedTrustBlocks false;
}

