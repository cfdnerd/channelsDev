FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    // --------------------------------------------------------------------- //
    // Run Profile
    // --------------------------------------------------------------------- //
    optRunMode production; // production | diagnostic
    optFirstFailureSnapshotEnable       true; // write first failure snapshot
    optAdjointRollbackGuardsEnable      false; // Ua/Ub rollback guards
    optTurbulenceStateRegularizationEnable false; // smooth k/omega positivity repair
    optClosureBoundedOmegaLimiterEnable false; // smooth omega limiter in nut

    // --------------------------------------------------------------------- //
    // Thermal Adjoint Selector
    // --------------------------------------------------------------------- //
    optThermalAdjointMode tbOriginal; // ta | tbOriginal | tbLaminar

    // --------------------------------------------------------------------- //
    // Thermal Objective/Constraint Targets
    // --------------------------------------------------------------------- //
    optThermalExcessTref          1.0;
    optThermalExcessSoftplusScale 0.5;
    optThermalTmaxLimit           15.0;
    optThermalTminLimit           0.0;
    optThermalKSBeta              24.0;

    // --------------------------------------------------------------------- //
    // MMA Step Controls
    // --------------------------------------------------------------------- //
    optPowerConstraintWeight      1.0;
    optVolumeConstraintWeight     2;
    optAdaptiveBaseMoveMin        0.4;
    optAdaptiveBaseMoveMax        0.4;
    optMmaMoveLimitFloor          1e-2;

    // --------------------------------------------------------------------- //
    // Laminar-Reference Warmup
    // --------------------------------------------------------------------- //
    optLaminarReferenceWarmupIterations        20;
    optLaminarReferenceWarmupMoveLimit         0.15;
    optLaminarReferenceWarmupResidualGrowthLimit 3.0;

    // --------------------------------------------------------------------- //
    // Convergence Stop
    // --------------------------------------------------------------------- //
    optMinIterations              50;
    optStallWindow                5;
    optObjectiveTol               1e-3;
    optConstraintTol              1e-3;
    optStepTol                    5e-3;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
