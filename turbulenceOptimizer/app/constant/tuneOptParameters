FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    // --------------------------------------------------------------------- //
    // Run Profile
    // --------------------------------------------------------------------- //
    optRunMode production; // production | diagnostic
    optFirstFailureSnapshotEnable       true; // write first failure snapshot
    optAdjointRollbackGuardsEnable      false; // Ua/Ub rollback guards (forced on in Pro mode when proModeAdjointStabilityPack=true)

    // --------------------------------------------------------------------- //
    // Thermal Adjoint Selector
    // --------------------------------------------------------------------- //
    optThermalAdjointMode ta; // ta | tb

    // --------------------------------------------------------------------- //
    // MMA Step Controls
    // --------------------------------------------------------------------- //
    optPowerConstraintWeight      1;
    optVolumeConstraintWeight     1;

    // --------------------------------------------------------------------- //
    // Formulation Controls
    // --------------------------------------------------------------------- //
    // Turbulence-closure denominator regularization controls.
    optClosureLogRegularizationEnable true;
    optClosureSmoothDenominatorEnable false;
    optKOmegaPositivityPreservingLinearizationEnable true;

    // Smooth projection (tanh) controls for Heaviside continuation.
    optProjectionSmoothingEnable false;
    optProjectionBetaScale    1.0;

    // Trust-ratio-based adaptive MMA move-limit controls.
    optAdaptiveMoveLimitEnable false;
    optAdaptiveMoveLimitMin            0.05;
    optAdaptiveMoveLimitMax            0.30;
    optAdaptiveMoveLimitTrustRatioShrink        0.25;
    optAdaptiveMoveLimitTrustRatioGrow          0.75;
    optAdaptiveMoveLimitShrinkFactor   0.70;
    optAdaptiveMoveLimitGrowFactor     1.15;
    optAdaptiveMoveLimitNegativeTrustDamping  0.50;

    // Wall-function diagnostics (high-Re coarse-mesh suitability checks).
    optWallFunctionYPlusDiagnosticsEnable true;
    optWallFunctionYPlusMin      30.0;
    optWallFunctionYPlusMax      300.0;
    optWallFunctionYPlusInBandWarnFraction 0.50; // Warn if in-band fraction falls below this.

    // --------------------------------------------------------------------- //
    // Thermal Envelope Constraints
    // --------------------------------------------------------------------- //
    optThermalEnvelopeConstraintsEnable false; // disable while tuning objFunction=3 to avoid envelope/obj coupling
    optThermalTmaxLimit           15.0; // upper envelope limit for Tmax KS constraint
    optThermalTminLimit           0.0; // lower envelope limit for Tmin KS constraint
    optThermalKSBeta              24.0; // KS aggregation sharpness for envelope constraints

    // --------------------------------------------------------------------- //
    // Thermal Excess Objective (ObjFunction 3: SmoothExcessT)
    // --------------------------------------------------------------------- //
    optThermalBoundedObjectiveEnable false; // required for SmoothExcessT when objFunction=3
    optThermalExcessTref          2.8; // focus objective on upper thermal tail (hotspot range)
    optThermalExcessSoftplusScale 0.75; // moderate smoothing: sharper than 1.0, safer than very small values

    // Convergence Stop
    // --------------------------------------------------------------------- //
    optMinIterations              50;
    optStallWindow                5;
    optObjectiveTol               1e-3;
    optConstraintTol              1e-3;
    optStepTol                    5e-3;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
