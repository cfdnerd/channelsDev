FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 2.0e2;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 2.0e2;
    }

    outlet
    {
        type            zeroGradient;
    }

    Wall
    {
        type            fixedValue;
        value           uniform 1e5;
    }

    right
    {
        type            symmetry;
    }

    frontAndBack
    {
        type            empty;
    }
}

